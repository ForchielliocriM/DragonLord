<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg118716.ui.controller.MainMenuController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="DragnLord" style="-fx-font-size: 36; -fx-text-fill: #f0c040; -fx-font-weight: bold;"/>

    <VBox spacing="12" alignment="CENTER" style="-fx-padding: 30 0 0 0;">
        <Button fx:id="newGameButton" text="⚔  Nuova Partita"
                onAction="#onNewGame" prefWidth="200" prefHeight="45"
                style="-fx-font-size: 14; -fx-background-color: #e94560;
                       -fx-text-fill: white; -fx-background-radius: 8;"/>

        <Button fx:id="loadGameButton" text="📂  Carica Partita"
                onAction="#onLoadGame" prefWidth="200" prefHeight="45"
                style="-fx-font-size: 14; -fx-background-color: #16213e;
                       -fx-text-fill: white; -fx-background-radius: 8;
                       -fx-border-color: #f0c040; -fx-border-radius: 8;"/>

        <Button text="✖  Esci"
                onAction="#onExit" prefWidth="200" prefHeight="45"
                style="-fx-font-size: 14; -fx-background-color: #16213e;
                       -fx-text-fill: #aaaaaa; -fx-background-radius: 8;
                       -fx-border-color: #555; -fx-border-radius: 8;"/>
    </VBox>
</VBox>